<?xml version="1.0" encoding="utf-8"?>
<!-- 「正在上课」行的圆角高亮底。用 shape drawable 而非 Glance cornerRadius(Dp)，
     以在 minSdk 26（cornerRadius(Dp) 仅 API 31+）上也有圆角。色值随明暗自适应。 -->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <solid android:color="@color/card_now_bg" />
    <stroke android:width="1dp" android:color="@color/card_row_border" />
    <corners android:radius="8dp" />
</shape>
